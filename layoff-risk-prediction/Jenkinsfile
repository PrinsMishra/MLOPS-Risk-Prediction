pipeline {
    agent any

    environment {
        DOCKER_USER = 'prins05688'
        DOCKER_CREDS = 'dockerhub-credentials'
    }

    stages {
        stage('1. Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('2. MLOps Retrain & Validate') {
            steps {
                dir('layoff-risk-prediction') {
                    script {
                        echo "Running automated retraining and artifact validation..."
                        sh '''
                        python3 -m venv venv || true
                        . venv/bin/activate
                        pip install -r requirements.txt
                        python scripts/retrain_pipeline.py --data mlops-dataset-layoff-risk/tech_layoffs_2025_2026.csv --models-dir models
                        
                        if [ ! -f "models/layoff_risk_model.keras" ]; then
                            echo "❌ Model artifact missing!"
                            exit 1
                        fi
                        '''
                    }
                }
            }
        }

        stage('3. Build Docker Images') {
            steps {
                dir('layoff-risk-prediction') {
                    echo "Building images with production tags..."
                    sh 'docker-compose build'
                }
            }
        }

        stage('4. Push to Docker Hub') {
            steps {
                script {
                    echo "Authenticating and pushing images to Docker Hub..."
                    withCredentials([usernamePassword(credentialsId: "${DOCKER_CREDS}", usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                        sh "echo \$PASS | docker login -u \$USER --password-stdin"
                        sh "docker push ${DOCKER_USER}/careershield-backend:latest"
                        sh "docker push ${DOCKER_USER}/careershield-frontend:latest"
                    }
                }
            }
        }

        stage('5. Deploy & Smoke Test') {
            steps {
                dir('layoff-risk-prediction') {
                    script {
                        echo "Restarting services and running health checks..."
                        sh 'docker-compose up -d'
                        
                        // Health check loop
                        sh '''
                        count=0
                        until $(curl --output /dev/null --silent --fail http://localhost:8000/health); do
                            if [ $count -eq 12 ]; then
                                echo "TIMEOUT: API failed to become healthy."
                                exit 1
                            fi
                            sleep 5
                            count=$((count+1))
                        done
                        '''
                        
                        echo "Running Smoke Test..."
                        sh '''
                        RESPONSE=$(curl -s -X POST "http://localhost:8000/predict" \
                          -H "Content-Type: application/json" \
                          -d '{
                            "industry": "Software",
                            "department": "Engineering",
                            "ai_exposure": "Partial",
                            "total_employees": 5000
                          }')
                        
                        if echo "$RESPONSE" | grep -q "risk_probability"; then
                            echo "✅ Smoke Test Passed!"
                        else
                            echo "❌ Smoke Test Failed!"
                            exit 1
                        fi
                        '''
                    }
                }
            }
        }
    }

    post {
        always {
            sh 'docker image prune -f'
        }
        success {
            echo "🏆 Full MLOps Automation Complete! Images pushed to Docker Hub."
        }
    }
}
