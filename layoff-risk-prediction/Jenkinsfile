pipeline {
    agent any

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Python Setup & Retraining') {
            steps {
                dir('layoff-risk-prediction') {
                    script {
                        echo "Setting up Python environment and running retraining gate..."
                        sh '''
                        # Create and activate virtual environment
                        python3 -m venv venv || true
                        . venv/bin/activate
                        pip install -r requirements.txt
                        
                        # Run the retraining script
                        python scripts/retrain_pipeline.py --data mlops-dataset-layoff-risk/tech_layoffs_2025_2026.csv --models-dir models
                        '''
                    }
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                dir('layoff-risk-prediction') {
                    script {
                        echo "Building Docker images to verify build health..."
                        sh '''
                        docker-compose build
                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            echo "✅ Pipeline Success! Code is healthy and model is updated."
        }
        failure {
            echo "❌ Pipeline Failed. Please check the logs."
        }
    }
}
